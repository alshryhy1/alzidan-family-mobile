{
  "expo": {
    "name": "عائلة الزيدان",
    "slug": "alzidan-family-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.alzidan.family",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "يحتاج التطبيق للوصول إلى الصور والفيديو عند إرفاق وسائط مع مناسبة عائلية أو ذكرى.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "supportsTablet": true,
      "appExtensions": [
        {
          "targetName": "AlzidanFamilyWidgetExtension",
          "bundleIdentifier": "com.alzidan.family.AlzidanFamilyWidgetExtension",
          "entitlements": {
            "com.apple.security.application-groups": [
              "group.com.alzidan.family"
            ]
          }
        }
      ]
    },
    "android": {
      "package": "com.alzidan.family",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "expo-notifications",
      "expo-sharing",
      "expo-image-picker",
      "expo-document-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "8a6659eb-ef85-49b5-a8db-7b7be96b8c1f"
      }
    },
    "owner": "alshryhy"
  }
}
